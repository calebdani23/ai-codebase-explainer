# Backend
DATABASE_URL=postgresql://user:password@host:5432/dbname
# Local fallback for developer-only testing when Postgres is unavailable:
# DATABASE_URL=sqlite:///./local_dev.db
# CORS entries are origins only (scheme + host + optional port), not paths.
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,https://YOUR_GITHUB_USERNAME.github.io
ENVIRONMENT=development
DEMO_MODE=true

# Optional backend-only key. If empty, analysis and issue triage use deterministic heuristics.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# Optional backend-only token for public GitHub API rate limits.
GITHUB_TOKEN=

MAX_REPO_SIZE_MB=25
MAX_FILE_SIZE_KB=300
MAX_FILES_ANALYZED=300

OBSERVABILITY_ENABLED=false
# Backend URL of the prior AI Agent Observability Dashboard API; the API appends /api/traces.
OBSERVABILITY_API_URL=https://YOUR_OBSERVABILITY_BACKEND_URL
# Backend-only ingest key. Never expose this as a VITE_* variable.
OBSERVABILITY_INGEST_API_KEY=
OBSERVABILITY_APP_NAME=ai-codebase-explainer

PORT=8000

# Frontend
VITE_API_URL=http://localhost:8000
VITE_DEMO_MODE=true
VITE_REPO_URL=https://github.com/YOUR_USERNAME/ai-codebase-explainer
# Public dashboard UI link only; no ingest key or backend secrets are exposed to GitHub Pages.
VITE_OBSERVABILITY_DASHBOARD_URL=https://calebdani23.github.io/ai-agent-observability-dashboard/
